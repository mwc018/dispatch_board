# =============================================
# Dispatch Board — Server Environment Variables
# Copy this file to server/.env and fill in values
# =============================================

# Server port (default: 3001)
PORT=3001

# URL of the React client (for CORS)
CLIENT_URL=http://localhost:5173

# =============================================
# Zoho CRM OAuth (Self-Client)
# Steps to get these:
# 1. Go to https://api-console.zoho.com
# 2. Create a "Self Client" application
# 3. Generate a grant token with scope:
#    ZohoCRM.modules.ALL,ZohoCRM.users.READ
# 4. Exchange for refresh token (one-time step)
# =============================================
ZOHO_CLIENT_ID=your_client_id_here
ZOHO_CLIENT_SECRET=your_client_secret_here
ZOHO_REFRESH_TOKEN=your_refresh_token_here

# Zoho accounts URL — use your region:
# US: https://accounts.zoho.com
# EU: https://accounts.zoho.eu
# AU: https://accounts.zoho.com.au
# IN: https://accounts.zoho.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Zoho API base URL — use your region:
# US: https://www.zohoapis.com/crm/v2
# EU: https://www.zohoapis.eu/crm/v2
# AU: https://www.zohoapis.com.au/crm/v2
ZOHO_API_BASE=https://www.zohoapis.com/crm/v2

# =============================================
# Zoho CRM Module & Field Mapping
# Set these to match your actual CRM field API names.
# To find field API names: CRM > Setup > Modules > Service_Orders > Fields
# =============================================

# Module name in Zoho CRM (default: Service_Orders)
ZOHO_MODULE_NAME=Service_Orders

# Field API names to update when assigning (leave blank to skip that field)
ZOHO_FIELD_TECH=Assigned_Tech
ZOHO_FIELD_PRIORITY=Dispatch_Priority
ZOHO_FIELD_TIME=Scheduled_Time
ZOHO_FIELD_STATUS=Dispatch_Status
